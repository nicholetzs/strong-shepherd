---
import { projects } from '../data/projects';
---

<section id="projetos" class="station-section section-reveal">
  <div class="section-shell">
    <p class="section-label">MISSOES ATIVAS</p>
    <h2 class="section-title">Projetos em painel de bordo.</h2>

    <div class="mission-grid">
      {projects.map((project) => (
        <article class="mission-card">
          <div class="mission-tape">{project.mission}</div>
          <div class="mission-monitor">
            <span class="monitor-line">STATUS: {project.status}</span>
            <span class="monitor-title">{project.title}</span>
          </div>
          <h2>{project.title}</h2>
          <p class="mission-stack">{project.stack.join(' · ')}</p>
          <p class="mission-description">{project.description}</p>
          <a class="mission-button" href={`/projects/${project.slug}/`}>ACESSAR MISSAO</a>
        </article>
      ))}
    </div>
  </div>
</section>
