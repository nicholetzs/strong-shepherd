---
import { modules } from '../data/modules';
import ModuleCard from './ModuleCard.astro';
---

<section id="modulos" class="station-section section-reveal">
  <div class="section-shell">
    <p class="section-label">MAPA DE MODULOS</p>
    <h2 class="section-title">Escolha um modulo da estacao.</h2>

    <div class="module-track">
      {modules.map((module) => (
        <ModuleCard module={module} />
      ))}
    </div>
  </div>
</section>
